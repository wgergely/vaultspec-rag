# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# HuggingFace access token — required for gated models (naver/splade-v3).
# Get yours at https://huggingface.co/settings/tokens
# Accept naver/splade-v3 terms at https://huggingface.co/naver/splade-v3
HF_TOKEN=hf_...

# ---------------------------------------------------------------------------
# vaultspec-rag configuration
# All settings follow the resolution order: CLI arg > env var > config default.
# See config.py EnvVar enum for the authoritative list.
# ---------------------------------------------------------------------------

# Project root directory (default: git root or cwd).
# CLI: --target
# VAULTSPEC_RAG_ROOT=

# RAG data root relative to project root (default: .vault/data/search-data).
# CLI: --data-dir
# VAULTSPEC_RAG_DATA_DIR=.vault/data/search-data

# Qdrant storage subdirectory relative to data root (default: qdrant).
# CLI: --qdrant-dir
# VAULTSPEC_RAG_QDRANT_DIR=qdrant

# Vault index metadata filename relative to data root (default: index_meta.json).
# CLI: --index-meta
# VAULTSPEC_RAG_INDEX_META=index_meta.json

# Code index metadata filename relative to data root (default: code_index_meta.json).
# CLI: --code-index-meta
# VAULTSPEC_RAG_CODE_INDEX_META=code_index_meta.json

# Service status directory — stores service.json and logs (default: ~/.vaultspec-rag).
# CLI: --status-dir
# VAULTSPEC_RAG_STATUS_DIR=~/.vaultspec-rag

# Service log filename relative to status dir (default: service.log).
# CLI: --log-file
# VAULTSPEC_RAG_LOG_FILE=service.log

# MCP server port (default: 8766).
# CLI: --port
# VAULTSPEC_RAG_PORT=8766

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: WARNING).
# CLI: --verbose (INFO) / --debug (DEBUG)
# VAULTSPEC_RAG_LOG_LEVEL=WARNING
